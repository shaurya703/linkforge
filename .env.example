# Copy to .env and adjust. docker-compose reads these.

# HTTP server
HTTP_ADDR=:8080
BASE_URL=http://localhost:8080
READ_TIMEOUT=5s
WRITE_TIMEOUT=10s
IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=15s

# Postgres
POSTGRES_DSN=postgres://linkforge:linkforge@localhost:5432/linkforge?sslmode=disable
POSTGRES_MAX_CONNS=20

# Redis
REDIS_ADDR=localhost:6379
REDIS_DB=0
CACHE_TTL=1h
CACHE_NEGATIVE_TTL=30s

# Rate limiting (token bucket, per client IP) on POST /shorten
RATELIMIT_RATE=10        # tokens refilled per second
RATELIMIT_BURST=20       # bucket capacity

# Async analytics pipeline
ANALYTICS_BUFFER=10000   # channel capacity
ANALYTICS_WORKERS=4
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL=2s
